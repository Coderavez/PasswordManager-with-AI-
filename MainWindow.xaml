<Window x:Class="PasswordManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Password Manager" Height="400" Width="600">

    <Grid Margin="10">
        <StackPanel>

            <PasswordBox x:Name="PasswordBox" Margin="0,0,0,10"/>

            <Button Content="Открыть" Click="Open_Click" Margin="0,0,0,10"/>

            <ListBox x:Name="ListBox" Height="200"/>

            <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                <Button Content="Добавить" Click="Add_Click" Width="100"/>
                <Button Content="Удалить" Click="Delete_Click" Width="100" Margin="10,0,0,0"/>
            </StackPanel>

        </StackPanel>
    </Grid>
</Window>